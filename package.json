{
  "name": "@fanslib/root",
  "private": true,
  "workspaces": [
    "@fanslib/apps/web",
    "@fanslib/apps/server",
    "@fanslib/apps/chrome-extension",
    "@fanslib/apps/electron-companion",
    "@fanslib/libraries/*",
    "@fanslib/configs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:dev": "turbo run build --filter=!@fanslib/web && cd @fanslib/apps/web && bun run build:dev",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "storybook": "turbo run storybook",
    "clean": "turbo run clean",
    "clear-appdata": "bun run --cwd @fanslib/apps/server clear-appdata",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "deploy": "./scripts/deploy.sh"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.168.3",
    "@tanstack/react-start": "^1.167.5",
    "fkill-cli": "^9.0.0",
    "sqlite3": "^5.1.7",
    "vite-plugin-node-polyfills": "^0.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "overrides": {
    "@tanstack/router-core": "1.168.3",
    "remotion": "4.0.441"
  },
  "packageManager": "bun@1.2.19"
}
